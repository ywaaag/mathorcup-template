# MathorCup Template — .gitignore

# Environment
.env
*.env.local

# Docker
.docker/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Output files (keep structure, ignore contents)
project/output/*
project/figures/*
!project/output/.gitkeep
!project/output/handoff/
!project/output/review/
!project/output/retrospectives/
project/output/handoff/*
project/output/review/*
project/output/retrospectives/*
!project/output/handoff/.gitkeep
!project/output/handoff/HANDOFF_TEMPLATE.md
!project/figures/.gitkeep
!project/output/review/.gitkeep
!project/output/review/WORKER_FEEDBACK_TEMPLATE.md
!project/output/retrospectives/.gitkeep
!project/output/retrospectives/RETROSPECTIVE_TEMPLATE.md

# Data files (keep structure, ignore contents)
project/data/*
!project/data/.gitkeep
!project/data/problem/
!project/data/raw/
!project/data/processed/
project/data/problem/*
project/data/raw/*
project/data/processed/*
!project/data/problem/.gitkeep
!project/data/raw/.gitkeep
!project/data/processed/.gitkeep

# Generated paper build artifacts
project/paper/*.pdf
project/paper/*.aux
project/paper/*.bbl
project/paper/*.bcf
project/paper/*.blg
project/paper/*.log
project/paper/*.out
project/paper/*.run.xml
project/paper/*.synctex.gz
project/paper/build/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary
*.tmp
*.swp
*.swo
