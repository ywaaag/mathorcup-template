# ============================================================
# 环境变量配置（复制为 .env 后修改）
# ============================================================

# 镜像名称（已拉取，直接使用）
IMAGE_NAME=math-modeling-competition:latest

# 比赛名称（用于容器名）
COMPETITION_NAME=mathorcup

# Docker 容器名
CONTAINER_NAME=mathorcup-dev

# Jupyter 端口
JUPYTER_PORT=8888

# RStudio 端口
RSTUDIO_PORT=8787

# Jupyter Token / 密码
JUPYTER_TOKEN=mathorcup

# 宿主机项目目录（挂载到容器内）
HOST_PROJECT_DIR=./project
